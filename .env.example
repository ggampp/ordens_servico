# ---- Database (PostgreSQL + PostGIS) ----
DB_USER=ordens
DB_PASSWORD=ordens
DB_NAME=ordens_servico
DB_PORT=5432

# The backend connects exclusively through this URL. When running outside
# Docker, point the host at localhost:
#   DATABASE_URL=postgres://ordens:ordens@localhost:5432/ordens_servico?sslmode=disable

# ---- Backend ----
BACKEND_PORT=8080
JWT_SECRET=change-me-in-production
JWT_EXPIRY_HOURS=24
LOG_LEVEL=info

# Initial admin seeded on first start (only if no admin exists yet).
SEED_ADMIN_EMAIL=admin@ordens.local
SEED_ADMIN_PASSWORD=admin123

# ---- Frontend ----
FRONTEND_PORT=3000
