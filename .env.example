# ---- Banco de dados (PostgreSQL + PostGIS) ----
# Configuração ÚNICA do banco. A URL de conexão já contém usuário, senha, host
# e nome do banco — não há variáveis separadas de usuário/senha/nome.
#
# - Deixe comentada para usar o Postgres embutido no docker-compose
#   (host "postgres", criado automaticamente).
# - Defina-a para apontar a um Postgres externo/gerenciado, por exemplo:
# DATABASE_URL=postgres://ordens_servico:senha-secreta@postgres:5432/ordens_servico?sslmode=disable

# ---- Backend ----
JWT_SECRET=change-me-in-production
JWT_EXPIRY_HOURS=24
LOG_LEVEL=info

# Admin semeado na primeira execução (apenas se ainda não houver admin).
SEED_ADMIN_EMAIL=admin@ordens.local
SEED_ADMIN_PASSWORD=admin123

# ---- Porta (host) ----
# A aplicação é um monólito: o backend Go serve a SPA e a API na MESMA porta.
# Esta é a porta exposta no host (e a que o reverse-proxy da plataforma usa).
APP_PORT=8080
